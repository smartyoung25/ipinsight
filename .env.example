# ─── Anthropic LLM ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── 특허 DB ──────────────────────────────────────────────
# EPO OPS (무료, developers.epo.org 등록 → Client ID + Secret 발급)
# 등록 후 아래 두 항목을 입력하면 PatentConnector가 자동으로 OAuth2 토큰 획득
EPO_CLIENT_ID=your_epo_client_id
EPO_CLIENT_SECRET=your_epo_client_secret

# (선택) KIPRIS / PATSNAP
KIPRIS_API_KEY=your_kipris_api_key_here
PATSNAP_API_KEY=your_patsnap_api_key_here

# ─── 임상·규제 DB ─────────────────────────────────────────
# FDA openFDA (무료, open.fda.gov/apis/authentication/ 등록)
# 미설정: 1,000 req/일 | 설정 시: 120,000 req/일
FDA_API_KEY=your_fda_api_key

# ─── 국내 R&D·정책 DB ────────────────────────────────────
# NTIS 국가R&D 과제 (무료, data.go.kr/data/15083528/openapi.do 신청)
NTIS_API_KEY=your_ntis_api_key

# ─── 시장 데이터 (선택) ────────────────────────────────────
STATISTA_API_KEY=your_statista_api_key_here

# ─── 서버 설정 ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8100
DEBUG=false

# ─── 출력 경로 ────────────────────────────────────────────
OUTPUT_DIR=./outputs
